# ─── Relay ───────────────────────────────────────────────────────────
# WebSocket port the relay listens on
PORT=4869

# Path to the SQLite database file (absolute or relative to relay working dir)
DB_PATH=relay.db

# ─── UI (Next.js) ────────────────────────────────────────────────────
# Public WebSocket URL for the relay. Browser clients connect to this.
# In development: ws://localhost:4869
# In production: wss://relay.your-domain.example  (or wss://your-domain.example/relay)
NEXT_PUBLIC_RELAY_URL=ws://localhost:4869

# ─── Docker Compose ──────────────────────────────────────────────────
# Passed as a build arg to the UI image so the browser knows where the relay is.
# For a VPS with a public IP and no domain yet:
#   RELAY_URL=ws://YOUR_SERVER_IP:4869
# For a domain with TLS (nginx in front):
#   RELAY_URL=wss://relay.your-domain.example
RELAY_URL=wss://relay.your-domain.example

# ─── Admin Backend ───────────────────────────────────────────────────
# Required for /admin and /api/admin/* access.
# Use a long random secret in production.
ADMIN_API_TOKEN=change-me-to-a-long-random-secret

# Optional JSON file paths for admin-managed overrides.
# Default to ./data/admin-*.json when unset.
ADMIN_PROFILE_STORE_PATH=data/admin-profiles.json
ADMIN_POST_STORE_PATH=data/admin-posts.json
ADMIN_COMMENT_STORE_PATH=data/admin-comments.json
